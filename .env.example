# ============================================================
#  .env.example — Copy to .env.local and fill in values
#  NEVER commit .env.local to git!
# ============================================================

# ── App ──────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-32-char-string-here

# ── Database (AWS RDS PostgreSQL) ────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@your-rds-endpoint.rds.amazonaws.com:5432/saas_pm_db

# ── AWS Cognito (Phase 3) ────────────────────────────────
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret
COGNITO_DOMAIN=your-cognito-domain.auth.us-east-1.amazoncognito.com
AWS_REGION=us-east-1

# ── AWS S3 (Phase 6 — file uploads) ─────────────────────
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=your-saas-pm-uploads
S3_REGION=us-east-1

# ── Sentry (Phase 7 — error monitoring) ─────────────────
SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000
NEXT_PUBLIC_SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000

# ── CloudWatch ───────────────────────────────────────────
CLOUDWATCH_LOG_GROUP=/saas-project-manager/prod
CLOUDWATCH_LOG_STREAM=app-logs
